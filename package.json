{
  "name": "popstrip",
  "version": "2.6.0",
  "private": true,
  "type": "module",
  "description": "A free, fun, browser-based photo booth — a faithful Photo Booth clone.",
  "license": "AGPL-3.0-or-later",
  "homepage": "https://popstrip.app",
  "scripts": {
    "dev": "vite",
    "predev": "node scripts/copy-mediapipe-wasm.mjs",
    "prebuild": "node scripts/copy-mediapipe-wasm.mjs",
    "build": "vite build",
    "preview": "vite preview --port 4173 --strictPort",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "deploy": "bash scripts/deploy.sh",
    "verify:render": "node tools/pb-verify/render.mjs",
    "verify:crop": "node tools/pb-verify/crop-refs.mjs",
    "verify:effects": "node tools/pb-verify/compare.mjs && node tools/pb-verify/report.mjs"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tsconfig/svelte": "^5.0.8",
    "playwright": "^1.61.1",
    "pngjs": "^7.0.0",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.3"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.35",
    "gifenc": "^1.0.3",
    "mediabunny": "^1.50.6",
    "pixi.js": "^8.19.0"
  }
}
